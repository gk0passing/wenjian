    "DEEPSEEK_JUDGE_MODEL",
    "deepseek-v4-flash",
)

MULTI_TABLE_JUDGE_MODEL = os.environ.get(
    "DEEPSEEK_MULTI_TABLE_JUDGE_MODEL",
    "deepseek-v4-pro",
