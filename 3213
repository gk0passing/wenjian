2. 替换 client 初始化

把 _make_judge_client() 改成：

def _make_judge_client():
    """Build a DeepSeek OpenAI-compatible client."""
    if not DEEPSEEK_API_KEY:
        return None

    try:
        return openai.OpenAI(
            api_key=DEEPSEEK_API_KEY,
            base_url=DEEPSEEK_BASE_URL,
            timeout=90.0,
            max_retries=3,
        )
    except Exception:
        return None
3. 替换 _call_judge

建议单表和多表都使用 JSON Output，避免解析 "true"、"false" 时误判。

def _call_judge(
    system_prompt: str,
    user_prompt: str,
    *,
    multi_table: bool,
) -> tuple[bool | float, dict]:
    """Score an answer with DeepSeek's OpenAI-compatible Chat API."""

    if _JUDGE_CLIENT is None:
        return (0.0 if multi_table else False), {
            "error": "DEEPSEEK_API_KEY is missing"
        }

    if multi_table:
        output_instruction = """
Return JSON only, using exactly this structure:

{
  "primary_data_score": 0,
  "derived_metrics_score": 0,
  "reasoning_score": 0,
  "consistency_score": 0,
  "completeness_score": 0,
  "structure_score": 0,
  "explanation": "brief explanation"
}

Every score must be a number from 0 to 100.
Do not output Markdown or any text outside the JSON object.
"""
        model = MULTI_TABLE_JUDGE_MODEL
        max_tokens = 1200
    else:
        output_instruction = """
Return JSON only, using exactly this structure:

{
  "correct": true,
  "explanation": "brief explanation"
}

Set correct to true only when the model answer matches the label.
Do not output Markdown or any text outside the JSON object.
"""
        model = JUDGE_MODEL
        max_tokens = 400

    messages = [
        {
            "role": "system",
            "content": system_prompt + "\n\n" + output_instruction,
        },
        {
            "role": "user",
            "content": user_prompt,
        },
    ]

    try:
        response = _JUDGE_CLIENT.chat.completions.create(
            model=model,
            messages=messages,
            max_tokens=max_tokens,
            response_format={"type": "json_object"},
            extra_body={
                "thinking": {
                    "type": "disabled",
                }
            },
        )

        content = response.choices[0].message.content or ""
        parsed = json.loads(content)

        if multi_table:
            weighted = 0.0
            total_weight = 0.0

            for key, weight in CORRECTNESS_WEIGHTS.items():
                value = parsed.get(key)

                if isinstance(value, int | float):
                    normalized = max(
                        0.0,
                        min(100.0, float(value)),
                    ) / 100.0

                    weighted += normalized * weight
                    total_weight += weight

            score = (
                weighted / total_weight
                if total_weight > 0
                else 0.0
            )

            return max(0.0, min(1.0, score)), parsed

        correct = parsed.get("correct", False)

        if isinstance(correct, str):
            correct = correct.strip().lower() == "true"

        return bool(correct), parsed

    except Exception as exc:
        return (0.0 if multi_table else False), {
            "error": type(exc).__name__,
            "message": str(exc),
        }

DeepSeek 的 JSON Output 需要设置：

response_format={"type": "json_object"}

同时提示词中必须明确要求输出 JSON，否则可能出现空白输出或请求看似卡住的情况。

代码里显式关闭了思考模式：

extra_body={"thinking": {"type": "disabled"}}

因为 DeepSeek V4 当前默认开启思考模式；对这种简单裁判任务，关闭思考通常可以减少延迟与 token 消耗。

